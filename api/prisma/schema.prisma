// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  user
}

model Specialty {
  name        String   @id @unique
  description String
  barbers     BarberSpecialty[]
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  credential   String
  name         String
  role  Role
  appointments Appointment[]
  refreshTokenSessions RefreshTokenSession[]
}

model Barber {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  specialties  BarberSpecialty[]
  bornAt Int 
  hiredAt DateTime
  appointments Appointment[]
}

model BarberSpecialty {
  id          Int     @id @default(autoincrement())
  barber      Barber  @relation(fields: [barberId], references: [id], onDelete: Cascade)
  barberId    Int
  specialty   Specialty @relation(fields: [specialtyName], references: [name], onDelete: Cascade)
  specialtyName String

  @@unique([barberId, specialtyName])
}

model Appointment {
  id       Int      @id @default(autoincrement())
  user     User     @relation(fields: [userId], references: [id])
  userId   Int
  barber   Barber   @relation(fields: [barberId], references: [id])
  barberId Int
  active Boolean
  datetime DateTime
}

model RefreshTokenSession {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  @@index([userId])
  @@index([expiresAt])
}
